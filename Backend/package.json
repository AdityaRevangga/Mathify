{
  "name": "mathify",
  "version": "1.0.0",
  "description": "Mathify - Platform Pembelajaran Matematika Online",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix ../frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "migrate": "node -e \"require('./src/config/database').query(require('fs').readFileSync('./migrations/001_init.sql','utf8')).then(()=>console.log('Migration done')).catch(e=>console.error(e))\"",
    "setup-db": "node setup-db.js"
  },
  "keywords": ["math", "learning", "education"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.7"
  }
}
